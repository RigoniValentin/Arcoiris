@import url("https://fonts.googleapis.com/css2?family=Inter:wght@100;200;300;400;500;600;700;800;900&family=Playfair+Display:wght@400;500;600;700;800;900&family=Space+Grotesk:wght@300;400;500;600;700&display=swap");

/* Reset moderno */
*,
*::before,
*::after {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
  font-size: 16px;
}

body {
  font-family:
    "Inter",
    -apple-system,
    BlinkMacSystemFont,
    "Segoe UI",
    system-ui,
    sans-serif;
  background-color: var(--background-primary);
  color: var(--text-primary);
  line-height: 1.7;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

#root {
  min-height: 100vh;
  width: 100%;
}

/* Variables CSS - Arcoiris Joyería Theme (Elegante, Profesional) */
:root {
  /* Colores de marca Arcoiris Joyería */
  --arcoiris-teal: #0E4E4E;
  --arcoiris-teal-light: #1a6b6b;
  --arcoiris-teal-dark: #093636;
  --arcoiris-cream: #D6ECF0;
  --arcoiris-cream-light: #eaf5f8;
  --arcoiris-gold: #C79B30;
  --arcoiris-gold-light: #e5c470;
  --arcoiris-gold-dark: #a07522;

  /* Fondos principales - Tema Elegante Claro */
  --background-primary: #fafcfd;
  --background-secondary: #f0f7f9;
  --background-tertiary: #D6ECF0;
  --background-accent: #0E4E4E;
  --background-elevated: #ffffff;
  --background-glass: rgba(214, 236, 240, 0.85);

  /* Textos */
  --text-primary: #0E4E4E;
  --text-secondary: #1a6b6b;
  --text-tertiary: #4a8a8a;
  --text-quaternary: #7aabab;
  --text-muted: #9ec3c3;
  --text-accent: #C79B30;

  /* Bordes y separadores */
  --border-primary: #d0e4e8;
  --border-secondary: #b8d6dc;
  --border-accent: #C79B30;
  --border-hover: #0E4E4E;

  /* Estados interactivos */
  --hover-background: #eaf5f8;
  --active-background: #D6ECF0;
  --focus-ring: #C79B30;

  /* Sombras elegantes */
  --shadow-sm: 0 1px 3px 0 rgba(14, 78, 78, 0.06);
  --shadow-md: 0 4px 12px -1px rgba(14, 78, 78, 0.08),
    0 2px 4px -1px rgba(14, 78, 78, 0.04);
  --shadow-lg: 0 10px 25px -3px rgba(14, 78, 78, 0.1),
    0 4px 10px -2px rgba(14, 78, 78, 0.05);
  --shadow-xl: 0 20px 40px -5px rgba(14, 78, 78, 0.12),
    0 10px 15px -5px rgba(14, 78, 78, 0.06);
  --shadow-2xl: 0 25px 60px -12px rgba(14, 78, 78, 0.18);
  --shadow-gold: 0 4px 15px rgba(199, 155, 48, 0.2);

  /* Gradientes elegantes */
  --gradient-primary: linear-gradient(
    135deg,
    #0E4E4E 0%,
    #1a6b6b 100%
  );
  --gradient-secondary: linear-gradient(
    135deg,
    #f0f7f9 0%,
    #D6ECF0 100%
  );
  --gradient-accent: linear-gradient(
    135deg,
    #C79B30 0%,
    #e5c470 100%
  );
  --gradient-gold: linear-gradient(
    135deg,
    #C79B30 0%,
    #f0d9a0 50%,
    #C79B30 100%
  );
  --gradient-hero: linear-gradient(
    160deg,
    #0E4E4E 0%,
    #1a6b6b 40%,
    #267878 100%
  );

  /* Espaciado */
  --space-xs: 0.25rem;
  --space-sm: 0.5rem;
  --space-md: 1rem;
  --space-lg: 1.5rem;
  --space-xl: 2rem;
  --space-2xl: 3rem;
  --space-3xl: 4rem;

  /* Radios de borde */
  --radius-sm: 0.375rem;
  --radius-md: 0.5rem;
  --radius-lg: 0.75rem;
  --radius-xl: 1rem;
  --radius-2xl: 1.5rem;

  /* Fuentes */
  --font-primary: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI",
    system-ui, sans-serif;
  --font-accent: "Playfair Display", Georgia, "Times New Roman", serif;
  --font-display: "Space Grotesk", -apple-system, BlinkMacSystemFont, "Segoe UI",
    system-ui, sans-serif;
}

/* Utilidades modernas */
.container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 var(--space-lg);
}

.container-wide {
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 var(--space-lg);
}

.container-narrow {
  max-width: 800px;
  margin: 0 auto;
  padding: 0 var(--space-lg);
}

.text-center {
  text-align: center;
}

.text-left {
  text-align: left;
}

.text-right {
  text-align: right;
}

.sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}

/* Botones modernos */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-sm);
  padding: var(--space-md) var(--space-xl);
  border: none;
  border-radius: var(--radius-lg);
  font-family: var(--font-primary);
  font-weight: 500;
  font-size: 0.875rem;
  line-height: 1.4;
  text-decoration: none;
  cursor: pointer;
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  user-select: none;
  white-space: nowrap;
}

.btn-primary {
  background: var(--gradient-primary);
  color: white;
  box-shadow: var(--shadow-md);
}

.btn-primary:hover {
  transform: translateY(-1px);
  box-shadow: var(--shadow-lg);
}

.btn-secondary {
  background: var(--background-elevated);
  color: var(--text-primary);
  border: 1px solid var(--border-primary);
}

.btn-secondary:hover {
  background: var(--hover-background);
  border-color: var(--border-secondary);
}

.btn-ghost {
  background: transparent;
  color: var(--text-secondary);
  border: 1px solid transparent;
}

.btn-ghost:hover {
  background: var(--hover-background);
  color: var(--text-primary);
}

/* Clases para truncar texto */
.line-clamp-1 {
  overflow: hidden;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  line-clamp: 1;
}

.line-clamp-2 {
  overflow: hidden;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  line-clamp: 2;
}

.line-clamp-3 {
  overflow: hidden;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  line-clamp: 3;
}

.line-clamp-4 {
  overflow: hidden;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 4;
  line-clamp: 4;
}

/* Efectos visuales modernos */
.glass-effect {
  background: var(--background-glass);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border: 1px solid var(--border-primary);
}

.glow-effect {
  box-shadow: 0 0 20px rgba(199, 155, 48, 0.3);
}

.floating {
  animation: floating 3s ease-in-out infinite;
}

@keyframes floating {
  0%,
  100% {
    transform: translateY(0px);
  }
  50% {
    transform: translateY(-10px);
  }
}

/* Responsive helpers */
.hidden-mobile {
  display: block;
}

.hidden-desktop {
  display: none;
}

@media (max-width: 768px) {
  .container,
  .container-wide,
  .container-narrow {
    padding: 0 var(--space-md);
  }

  .hidden-mobile {
    display: none;
  }

  .hidden-desktop {
    display: block;
  }
}
