/* Shop Section Styles - Professional Clean Design */
.shop {
  position: relative;
  min-height: 100vh;
  background: #ffffff;
  padding: 100px 0;
  overflow: hidden;
}

/* Ajuste cuando no hay navigation visible (sin admin) */
.shop.noNavigation {
  padding: 80px 0;
}

.container {
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 24px;
  position: relative;
  z-index: 10;
}

/* Background Effects - Subtle Green Accents */
.backgroundEffects {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 1;
}

.gradientOrb1 {
  position: absolute;
  top: 15%;
  left: 8%;
  width: 300px;
  height: 300px;
  background: linear-gradient(
    135deg,
    rgba(34, 197, 94, 0.06) 0%,
    rgba(16, 185, 129, 0.03) 100%
  );
  border-radius: 50%;
  filter: blur(80px);
  animation: float 25s ease-in-out infinite;
}

.gradientOrb2 {
  position: absolute;
  top: 65%;
  right: 12%;
  width: 250px;
  height: 250px;
  background: linear-gradient(
    135deg,
    rgba(5, 150, 105, 0.05) 0%,
    rgba(34, 197, 94, 0.02) 100%
  );
  border-radius: 50%;
  filter: blur(70px);
  animation: float 30s ease-in-out infinite reverse;
}

.gradientOrb3 {
  position: absolute;
  top: 40%;
  left: 70%;
  width: 180px;
  height: 180px;
  background: linear-gradient(
    135deg,
    rgba(16, 185, 129, 0.04) 0%,
    rgba(5, 150, 105, 0.02) 100%
  );
  border-radius: 50%;
  filter: blur(60px);
  animation: float 20s ease-in-out infinite;
}

/* Header Section */
.header {
  text-align: center;
  margin-bottom: 80px;
  opacity: 0;
  transform: translateY(30px);
  animation: fadeInUp 0.8s ease-out 0.2s forwards;
}

.headerBadge {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  background: linear-gradient(
    135deg,
    rgba(34, 197, 94, 0.1),
    rgba(16, 185, 129, 0.08)
  );
  padding: 12px 24px;
  border-radius: 50px;
  font-size: 14px;
  font-weight: 600;
  color: #047857;
  margin-bottom: 24px;
  border: 1px solid rgba(34, 197, 94, 0.2);
  backdrop-filter: blur(10px);
}

.badgeIcon {
  font-size: 18px;
}

.title {
  font-size: 4rem;
  font-weight: 900;
  margin-bottom: 20px;
  line-height: 1.1;
  background: linear-gradient(135deg, #1f2937 0%, #047857 100%);
  background-clip: text;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.highlight {
  background: linear-gradient(135deg, #047857, #059669);
  background-clip: text;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  font-weight: 900;
  position: relative;
}

.subtitle {
  font-size: 1.3rem;
  color: #6b7280;
  max-width: 700px;
  margin: 0 auto;
  line-height: 1.6;
  font-weight: 400;
}

/* Search and Filters Section */
.searchSection {
  margin-bottom: 60px;
  opacity: 0;
  transform: translateY(30px);
  animation: fadeInUp 0.8s ease-out 0.4s forwards;
}

.searchContainer {
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(20px);
  border-radius: 24px;
  padding: 32px;
  border: 1px solid rgba(0, 0, 0, 0.06);
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.05);
}

.searchBar {
  position: relative;
  margin-bottom: 24px;
}

.searchInput {
  width: 100%;
  padding: 18px 24px 18px 60px;
  border: 2px solid rgba(0, 0, 0, 0.08);
  border-radius: 16px;
  font-size: 16px;
  background: rgba(255, 255, 255, 0.9);
  transition: all 0.3s ease;
  font-weight: 500;
}

.searchInput:focus {
  outline: none;
  border-color: #047857;
  box-shadow: 0 0 0 4px rgba(4, 120, 87, 0.1);
  background: #ffffff;
}

.searchIcon {
  position: absolute;
  left: 20px;
  top: 50%;
  transform: translateY(-50%);
  color: #6b7280;
  font-size: 20px;
}

.filterRow {
  display: grid;
  grid-template-columns: 1fr auto auto;
  gap: 20px;
  align-items: center;
}

.sortSelect {
  padding: 16px 20px;
  border: 2px solid rgba(0, 0, 0, 0.08);
  border-radius: 12px;
  background: rgba(255, 255, 255, 0.9);
  font-size: 14px;
  font-weight: 500;
  min-width: 180px;
  cursor: pointer;
  transition: all 0.3s ease;
}

.sortSelect:focus {
  outline: none;
  border-color: #047857;
  box-shadow: 0 0 0 4px rgba(4, 120, 87, 0.1);
}

.filterToggle {
  padding: 16px 24px;
  background: linear-gradient(135deg, #047857, #059669);
  color: white;
  border: none;
  border-radius: 12px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  gap: 10px;
  box-shadow: 0 8px 25px rgba(4, 120, 87, 0.3);
}

.filterToggle:hover {
  transform: translateY(-2px);
  box-shadow: 0 12px 35px rgba(4, 120, 87, 0.4);
}

.advancedFilters {
  margin-top: 24px;
  padding: 24px;
  background: rgba(248, 250, 252, 0.8);
  border-radius: 16px;
  border: 1px solid rgba(0, 0, 0, 0.04);
}

.filterGroup {
  margin-bottom: 20px;
}

.filterLabel {
  display: block;
  font-weight: 600;
  color: #374151;
  margin-bottom: 12px;
  font-size: 14px;
}

.priceRange {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.rangeSlider {
  width: 100%;
  height: 8px;
  border-radius: 4px;
  background: rgba(0, 0, 0, 0.08);
  outline: none;
  -webkit-appearance: none;
  appearance: none;
}

.rangeSlider::-webkit-slider-thumb {
  -webkit-appearance: none;
  appearance: none;
  width: 24px;
  height: 24px;
  border-radius: 50%;
  background: #047857;
  cursor: pointer;
  box-shadow: 0 4px 12px rgba(4, 120, 87, 0.3);
}

.rangeSlider::-moz-range-thumb {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  background: #047857;
  cursor: pointer;
  border: none;
  box-shadow: 0 4px 12px rgba(4, 120, 87, 0.3);
}

.rangeValues {
  display: flex;
  justify-content: space-between;
  font-weight: 600;
  color: #047857;
}

/* Categories Section */
.categoriesSection {
  margin-bottom: 70px;
  opacity: 0;
  transform: translateY(30px);
  animation: fadeInUp 0.8s ease-out 0.6s forwards;
}

.categoriesGrid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 24px;
}

.categoryCard {
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20px);
  border-radius: 20px;
  padding: 32px 28px;
  text-align: center;
  border: 1px solid rgba(0, 0, 0, 0.06);
  transition: all 0.4s ease;
  cursor: pointer;
  position: relative;
  overflow: hidden;
  opacity: 0;
  transform: translateY(30px);
  animation: fadeInUp 0.6s ease-out forwards;
}

.categoryCard:nth-child(1) {
  animation-delay: 0.1s;
}
.categoryCard:nth-child(2) {
  animation-delay: 0.2s;
}
.categoryCard:nth-child(3) {
  animation-delay: 0.3s;
}
.categoryCard:nth-child(4) {
  animation-delay: 0.4s;
}
.categoryCard:nth-child(5) {
  animation-delay: 0.5s;
}
.categoryCard:nth-child(6) {
  animation-delay: 0.6s;
}
.categoryCard:nth-child(7) {
  animation-delay: 0.7s;
}

.categoryCard::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 2px;
  background: linear-gradient(90deg, transparent, #047857, transparent);
  transform: translateX(-100%);
  transition: transform 0.6s ease;
}

.categoryCard:hover::before {
  transform: translateX(100%);
}

.categoryCard:hover {
  transform: translateY(-8px);
  box-shadow: 0 25px 60px rgba(0, 0, 0, 0.1);
  border-color: rgba(4, 120, 87, 0.2);
}

.categoryCard.active {
  background: linear-gradient(
    135deg,
    rgba(4, 120, 87, 0.08),
    rgba(16, 185, 129, 0.05)
  );
  border-color: rgba(4, 120, 87, 0.3);
  transform: translateY(-4px);
  box-shadow: 0 20px 50px rgba(4, 120, 87, 0.15);
}

.categoryIcon {
  font-size: 3.5rem;
  margin-bottom: 20px;
  display: block;
  filter: grayscale(20%);
  transition: filter 0.3s ease;
}

.categoryCard:hover .categoryIcon {
  filter: grayscale(0%);
}

.categoryName {
  font-size: 1.6rem;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 12px;
  line-height: 1.2;
}

.categoryDescription {
  color: #6b7280;
  font-size: 1rem;
  margin-bottom: 16px;
  line-height: 1.5;
  font-weight: 400;
}

.categoryCount {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: rgba(4, 120, 87, 0.1);
  color: #047857;
  padding: 8px 16px;
  border-radius: 25px;
  font-size: 0.9rem;
  font-weight: 600;
}

/* Products Section */
.productsSection {
  opacity: 0;
  transform: translateY(30px);
  animation: fadeInUp 0.8s ease-out 0.8s forwards;
}

.productsHeader {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 50px;
  flex-wrap: wrap;
  gap: 20px;
}

.productsTitle {
  font-size: 2.5rem;
  font-weight: 800;
  color: #1f2937;
  line-height: 1.2;
}

.productsCount {
  color: #6b7280;
  font-size: 1.1rem;
  font-weight: 500;
  background: rgba(0, 0, 0, 0.04);
  padding: 8px 16px;
  border-radius: 20px;
}

.productsGrid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 32px;
  margin-bottom: 80px;
}

.productCard {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20px);
  border-radius: 20px;
  overflow: hidden;
  border: 2px solid rgba(4, 120, 87, 0.08);
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.06);
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  cursor: pointer;
  position: relative;
  opacity: 0;
  transform: translateY(30px);
  animation: fadeInUp 0.6s ease-out forwards;
  display: flex;
  flex-direction: column;
}

.productCard:hover {
  transform: translateY(-8px);
  box-shadow: 0 25px 60px rgba(4, 120, 87, 0.15);
  border-color: rgba(4, 120, 87, 0.25);
  background: rgba(255, 255, 255, 0.98);
}

.productCard.featured {
  border-color: rgba(4, 120, 87, 0.4);
  background: linear-gradient(
    135deg,
    rgba(255, 255, 255, 0.98),
    rgba(4, 120, 87, 0.03)
  );
  box-shadow: 0 12px 40px rgba(4, 120, 87, 0.1);
}

.productImageContainer {
  position: relative;
  width: 100%;
  height: 250px;
  overflow: hidden;
  background: linear-gradient(135deg, #f8fafc, #f1f5f9);
}

.productImage {
  width: 100%;
  height: 100%;
  object-fit: contain;
  transition: transform 0.6s ease;
}

.productCard:hover .productImage {
  transform: scale(1.1);
}

.productBadges {
  position: absolute;
  top: 16px;
  left: 16px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  z-index: 3;
}

.discountBadge {
  background: linear-gradient(135deg, #ef4444, #dc2626);
  color: white;
  padding: 6px 12px;
  border-radius: 20px;
  font-size: 0.8rem;
  font-weight: 700;
  box-shadow: 0 4px 15px rgba(239, 68, 68, 0.4);
}

.featuredBadge {
  background: linear-gradient(135deg, #047857, #059669);
  color: white;
  padding: 6px 12px;
  border-radius: 20px;
  font-size: 0.8rem;
  font-weight: 700;
  box-shadow: 0 4px 15px rgba(4, 120, 87, 0.4);
}

.productOverlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(
    135deg,
    rgba(0, 0, 0, 0.6),
    rgba(4, 120, 87, 0.4)
  );
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.productCard:hover .productOverlay {
  opacity: 1;
}

.quickViewBtn {
  background: rgba(255, 255, 255, 0.95);
  border: none;
  border-radius: 50%;
  width: 60px;
  height: 60px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.3s ease;
  color: #047857;
  font-size: 20px;
  backdrop-filter: blur(10px);
  box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
}

.quickViewBtn:hover {
  transform: scale(1.1);
  background: #ffffff;
}

.productInfo {
  padding: 28px;
  display: flex;
  flex-direction: column;
  flex-grow: 1;
}

/* Sección superior: Categoría y nombre */
.productHeader {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.productCategory {
  font-size: 0.85rem;
  color: #047857;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
  background: rgba(4, 120, 87, 0.1);
  padding: 6px 12px;
  border-radius: 12px;
  width: fit-content;
  margin-bottom: 12px;
}

.productName {
  font-size: 1.4rem;
  font-weight: 700;
  color: #1f2937;
  line-height: 1.3;
  margin: 0 0 16px 0;
}

.productDescription {
  font-size: 1rem;
  color: #6b7280;
  line-height: 1.6;
  margin: 0 0 20px 0;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* Sección media: Especificaciones y tags */
.productSpecs {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.productRating {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 16px;
}

.stars {
  display: flex;
  gap: 2px;
  font-size: 1rem;
}

.starFilled {
  color: #fbbf24;
}

.star {
  color: #d1d5db;
}

.ratingValue {
  font-size: 0.9rem;
  font-weight: 600;
  color: #6b7280;
}

.productTags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 16px;
}

.tag {
  background: rgba(59, 130, 246, 0.1);
  color: #3b82f6;
  padding: 6px 12px;
  border-radius: 8px;
  font-size: 0.8rem;
  font-weight: 600;
}

.stockInfo {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 0.9rem;
  font-weight: 600;
  margin-bottom: 20px;
}

.stockDot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
}

.inStock .stockDot {
  background: #10b981;
}

.outOfStock .stockDot {
  background: #ef4444;
}

.inStock {
  color: #10b981;
}

.outOfStock {
  color: #ef4444;
}

.productPrice {
  font-size: 1.8rem;
  font-weight: 800;
  color: #059669;
  margin-bottom: 16px;
  text-align: center;
}

.originalPrice {
  font-size: 1.2rem;
  color: #9ca3af;
  text-decoration: line-through;
  margin-right: 8px;
}

.currentPrice {
  font-size: 1.8rem;
  color: #059669;
  font-weight: 800;
}

.addToCartBtn {
  background: linear-gradient(135deg, #059669, #047857);
  color: white;
  border: none;
  border-radius: 12px;
  padding: 14px 20px;
  font-size: 1rem;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  min-height: 48px;
  width: 100%;
  margin-top: auto;
}

.addToCartBtn:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 25px rgba(5, 150, 105, 0.3);
  background: linear-gradient(135deg, #047857, #065f46);
}

/* Sección de acciones (tercera columna) */
.productActions {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16px;
  min-width: 200px;
  padding: 8px 0;
}

.productPricing {
  text-align: right;
}

.productPrice {
  font-size: 1.5rem;
  font-weight: 800;
  color: #059669;
  margin-bottom: 4px;
}

.originalPrice {
  font-size: 1rem;
  color: #9ca3af;
  text-decoration: line-through;
  margin-right: 8px;
}

.currentPrice {
  font-size: 1.5rem;
  color: #059669;
  font-weight: 800;
}

.priceNote {
  font-size: 0.75rem;
  color: #6b7280;
  margin-top: 2px;
}

.actionButtons {
  display: flex;
  flex-direction: column;
  gap: 8px;
  width: 100%;
}

.addToCartBtn {
  background: linear-gradient(135deg, #059669, #047857);
  color: white;
  border: none;
  border-radius: 12px;
  padding: 12px 20px;
  font-size: 0.9rem;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  min-height: 44px;
}

.addToCartBtn:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 25px rgba(5, 150, 105, 0.3);
  background: linear-gradient(135deg, #047857, #065f46);
}

.contactBtn {
  background: transparent;
  color: #059669;
  border: 2px solid #059669;
  border-radius: 12px;
  padding: 10px 20px;
  font-size: 0.85rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
}

.contactBtn:hover {
  background: #059669;
  color: white;
  transform: translateY(-1px);
}

.productName {
  font-size: 1.4rem;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 12px;
  line-height: 1.3;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.productDescription {
  color: #6b7280;
  font-size: 1rem;
  margin-bottom: 20px;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.productRating {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 16px;
}

.stars {
  display: flex;
  gap: 3px;
}

.starFilled {
  color: #fbbf24;
  font-size: 1.1rem;
  filter: drop-shadow(0 2px 4px rgba(251, 191, 36, 0.3));
}

.star {
  color: #e5e7eb;
  font-size: 1.1rem;
}

.ratingValue {
  color: #6b7280;
  font-size: 0.9rem;
  font-weight: 500;
}

.productTags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 24px;
}

.tag {
  background: rgba(4, 120, 87, 0.1);
  color: #047857;
  padding: 6px 12px;
  border-radius: 20px;
  font-size: 0.75rem;
  font-weight: 600;
  border: 1px solid rgba(4, 120, 87, 0.2);
}

.productFooter {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  padding-top: 20px;
  border-top: 1px solid rgba(0, 0, 0, 0.06);
}

.productPrice {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.originalPrice {
  font-size: 1rem;
  color: #9ca3af;
  text-decoration: line-through;
  font-weight: 500;
}

.currentPrice {
  font-size: 1.6rem;
  font-weight: 800;
  color: #047857;
  line-height: 1;
}

.productStock {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 0.9rem;
  font-weight: 600;
}

.stockDot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: currentColor;
}

.inStock {
  color: #047857;
}

.outOfStock {
  color: #ef4444;
}

.noProducts {
  text-align: center;
  padding: 80px 20px;
  color: #6b7280;
}

.noProductsIcon {
  font-size: 5rem;
  margin-bottom: 24px;
  opacity: 0.6;
}

.noProducts h3 {
  font-size: 1.8rem;
  font-weight: 700;
  margin-bottom: 12px;
  color: #374151;
}

.noProducts p {
  font-size: 1.1rem;
  line-height: 1.6;
}

/* Enhanced Product Modal */
.productModal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  backdrop-filter: blur(15px);
  opacity: 0;
  animation: fadeIn 0.3s ease forwards;
}

.modalContent {
  background: rgba(255, 255, 255, 0.98);
  backdrop-filter: blur(30px);
  border-radius: 24px;
  max-width: 1200px;
  width: 95%;
  max-height: 95vh;
  overflow: hidden;
  border: 1px solid rgba(4, 120, 87, 0.1);
  transform: scale(0.9);
  animation: scaleIn 0.3s ease forwards;
  position: relative;
  box-shadow: 0 40px 120px rgba(0, 0, 0, 0.2);
}

.closeButton {
  position: absolute;
  top: 20px;
  right: 20px;
  width: 40px;
  height: 40px;
  background: rgba(255, 255, 255, 0.9);
  border: 1px solid rgba(4, 120, 87, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.3s ease;
  z-index: 10;
  color: #047857;
  backdrop-filter: blur(10px);
}

.closeButton:hover {
  background: rgba(4, 120, 87, 0.1);
  transform: scale(1.1);
}

.modalBody {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 40px;
  padding: 40px;
  max-height: 95vh;
  overflow-y: auto;
}

/* Left Section - Images */
.modalImageSection {
  position: relative;
}

.modalImageContainer {
  position: relative;
  margin-bottom: 20px;
}

.modalMainImage {
  width: 100%;
  height: 400px;
  object-fit: contain;
  border-radius: 16px;
  background: linear-gradient(135deg, #f8fafc, #f1f5f9);
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
}

.modalFeaturedBadge {
  position: absolute;
  top: 16px;
  left: 16px;
  background: linear-gradient(135deg, #047857, #059669);
  color: white;
  padding: 8px 16px;
  border-radius: 20px;
  font-size: 0.85rem;
  font-weight: 700;
  box-shadow: 0 4px 15px rgba(4, 120, 87, 0.4);
}

.modalDiscountBadge {
  position: absolute;
  top: 16px;
  right: 16px;
  background: linear-gradient(135deg, #ef4444, #dc2626);
  color: white;
  padding: 8px 16px;
  border-radius: 20px;
  font-size: 0.85rem;
  font-weight: 700;
  box-shadow: 0 4px 15px rgba(239, 68, 68, 0.4);
}

.imageGallery {
  display: flex;
  gap: 12px;
  justify-content: center;
  flex-wrap: wrap;
}

.galleryThumb {
  width: 60px;
  height: 60px;
  border: 2px solid rgba(4, 120, 87, 0.2);
  border-radius: 8px;
  overflow: hidden;
  cursor: pointer;
  transition: all 0.3s ease;
  background: white;
}

.galleryThumb:hover,
.galleryThumb.active {
  border-color: #047857;
  transform: scale(1.05);
  box-shadow: 0 4px 16px rgba(4, 120, 87, 0.3);
}

.galleryThumb img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* Right Section - Product Info */
.modalInfoSection {
  display: flex;
  flex-direction: column;
  gap: 24px;
}

.modalHeader {
  border-bottom: 1px solid rgba(4, 120, 87, 0.1);
  padding-bottom: 20px;
}

.modalCategory {
  font-size: 0.9rem;
  color: #047857;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 8px;
}

.modalTitle {
  font-size: 2rem;
  font-weight: 800;
  color: #1f2937;
  margin-bottom: 16px;
  line-height: 1.2;
}

.modalRating {
  display: flex;
  align-items: center;
  gap: 12px;
}

.ratingText {
  color: #6b7280;
  font-size: 0.9rem;
  font-weight: 500;
}

.modalDescription {
  color: #6b7280;
  font-size: 1.1rem;
  line-height: 1.6;
}

.modalTags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.modalTag {
  background: rgba(4, 120, 87, 0.1);
  color: #047857;
  padding: 6px 12px;
  border-radius: 16px;
  font-size: 0.85rem;
  font-weight: 600;
  border: 1px solid rgba(4, 120, 87, 0.2);
}

.modalPriceSection {
  background: rgba(4, 120, 87, 0.05);
  padding: 20px;
  border-radius: 16px;
  border: 1px solid rgba(4, 120, 87, 0.1);
}

.modalPriceContainer {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 12px;
}

.modalOriginalPrice {
  font-size: 1.1rem;
  color: #9ca3af;
  text-decoration: line-through;
  font-weight: 500;
}

.modalCurrentPrice {
  font-size: 2rem;
  font-weight: 800;
  color: #047857;
  line-height: 1;
}

.modalStock {
  display: flex;
  align-items: center;
  gap: 8px;
}

.stockIndicator {
  font-size: 0.9rem;
  font-weight: 600;
}

.stockIndicator.inStock {
  color: #047857;
}

.stockIndicator.outOfStock {
  color: #ef4444;
}

.modalSpecifications {
  background: #f8fafc;
  padding: 20px;
  border-radius: 16px;
  border: 1px solid rgba(0, 0, 0, 0.05);
}

.specsTitle {
  font-size: 1.1rem;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 16px;
}

.modalSpecList {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.modalSpecItem {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0;
  border-bottom: 1px solid rgba(0, 0, 0, 0.05);
}

.modalSpecItem:last-child {
  border-bottom: none;
}

.modalSpecKey {
  font-weight: 600;
  color: #374151;
  font-size: 0.95rem;
}

.modalSpecValue {
  color: #6b7280;
  font-size: 0.95rem;
  text-align: right;
}

.modalFooter {
  border-top: 1px solid rgba(4, 120, 87, 0.1);
  padding-top: 24px;
  margin-top: auto;
}

.modalQuantitySection {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 20px;
}

.quantityLabel {
  font-weight: 600;
  color: #374151;
  font-size: 1rem;
}

.modalQuantitySelector {
  display: flex;
  align-items: center;
  gap: 8px;
  background: white;
  border: 2px solid rgba(4, 120, 87, 0.2);
  border-radius: 12px;
  padding: 8px 12px;
}

.modalQuantityBtn {
  background: rgba(4, 120, 87, 0.1);
  border: 1px solid rgba(4, 120, 87, 0.3);
  color: #047857;
  border-radius: 6px;
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.2s ease;
}

.modalQuantityBtn:hover:not(:disabled) {
  background: rgba(4, 120, 87, 0.2);
  transform: scale(1.05);
}

.modalQuantityBtn:disabled {
  background: rgba(156, 163, 175, 0.1);
  border-color: rgba(156, 163, 175, 0.3);
  color: #9ca3af;
  cursor: not-allowed;
  opacity: 0.6;
}

.modalQuantityDisplay {
  min-width: 32px;
  text-align: center;
  font-weight: 700;
  color: #047857;
  font-size: 1.1rem;
}

.modalActions {
  display: flex;
  gap: 12px;
}

.modalAddToCart {
  flex: 2;
  background: linear-gradient(135deg, #22c55e, #16a34a);
  color: white;
  border: none;
  border-radius: 12px;
  padding: 16px 24px;
  font-size: 1rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  box-shadow: 0 4px 16px rgba(34, 197, 94, 0.3);
}

.modalAddToCart:hover:not(:disabled) {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(34, 197, 94, 0.4);
}

.modalAddToCart:disabled {
  background: #9ca3af;
  cursor: not-allowed;
  opacity: 0.7;
}

.modalContactExpert {
  flex: 1;
  background: white;
  color: #047857;
  border: 2px solid #047857;
  border-radius: 12px;
  padding: 16px 24px;
  font-size: 1rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
}

.modalContactExpert:hover:not(:disabled) {
  background: rgba(4, 120, 87, 0.1);
  transform: translateY(-2px);
}

/* Product Card Cart Button */
.productActions {
  margin-top: 12px;
}

.specValue {
  color: #1f2937;
  font-weight: 500;
  font-size: 0.95rem;
}

.modalActions {
  display: flex;
  gap: 16px;
  margin-top: 32px;
}

.addToCart,
.contactSeller {
  flex: 1;
  padding: 18px 28px;
  border: none;
  border-radius: 16px;
  font-size: 1.1rem;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
}

.addToCart {
  background: linear-gradient(135deg, #047857, #059669);
  color: white;
  box-shadow: 0 8px 25px rgba(4, 120, 87, 0.3);
  position: relative;
  overflow: hidden;
}

.addToCart:hover {
  transform: translateY(-2px);
  box-shadow: 0 12px 35px rgba(4, 120, 87, 0.4);
}

.addToCart:active {
  transform: translateY(0);
  box-shadow: 0 6px 20px rgba(4, 120, 87, 0.3);
}

.addToCart.loading {
  pointer-events: none;
}

.addToCart.loading::after {
  content: "";
  position: absolute;
  top: 0;
  left: -100%;
  width: 300%;
  height: 100%;
  background: linear-gradient(
    90deg,
    rgba(255, 255, 255, 0) 0%,
    rgba(255, 255, 255, 0.2) 50%,
    rgba(255, 255, 255, 0) 100%
  );
  animation: loadingEffect 1.5s infinite;
}

.contactSeller {
  background: rgba(0, 0, 0, 0.06);
  color: #1f2937;
  border: 1px solid rgba(0, 0, 0, 0.1);
  position: relative;
  overflow: hidden;
}

.contactSeller:hover {
  background: rgba(0, 0, 0, 0.1);
  transform: translateY(-2px);
  box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
}

.contactSeller:active {
  transform: translateY(0);
  box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
}

.contactSeller.loading {
  pointer-events: none;
}

.contactSeller.loading::after {
  content: "";
  position: absolute;
  top: 0;
  left: -100%;
  width: 300%;
  height: 100%;
  background: linear-gradient(
    90deg,
    rgba(0, 0, 0, 0) 0%,
    rgba(0, 0, 0, 0.1) 50%,
    rgba(0, 0, 0, 0) 100%
  );
  animation: loadingEffect 1.5s infinite;
}
/* ===== CART STYLES ===== */

/* Header Cart Button */
.headerTop {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24px;
}

/* Los estilos del cartButton ya no son necesarios ya que ahora usamos el carrito flotante */

/* Los estilos del cartCount ya no son necesarios ya que ahora usamos el carrito flotante */

@keyframes pulse {
  0%,
  100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.1);
  }
}

/* Product Card Cart Button */
.productActions {
  margin-top: 12px;
}

.addToCartBtn {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 10px 16px;
  background: linear-gradient(135deg, #22c55e, #16a34a);
  color: white;
  border: none;
  border-radius: 8px;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.addToCartBtn:hover:not(:disabled) {
  transform: translateY(-1px);
  box-shadow: 0 4px 16px rgba(34, 197, 94, 0.3);
}

.addToCartBtn:active:not(:disabled) {
  transform: translateY(0);
  box-shadow: 0 2px 8px rgba(34, 197, 94, 0.2);
}

.addToCartBtn.loading {
  pointer-events: none;
}

.addToCartBtn.loading::after {
  content: "";
  position: absolute;
  top: 0;
  left: -100%;
  width: 300%;
  height: 100%;
  background: linear-gradient(
    90deg,
    rgba(255, 255, 255, 0) 0%,
    rgba(255, 255, 255, 0.2) 50%,
    rgba(255, 255, 255, 0) 100%
  );
  animation: loadingEffect 1.5s infinite;
}

.addToCartBtn:disabled {
  background: #9ca3af;
  cursor: not-allowed;
  opacity: 0.7;
}

/* Cart Modal */
.cartModal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 20px;
  backdrop-filter: blur(4px);
}

.cartModalContent {
  background: #ffffff;
  border-radius: 20px;
  width: 100%;
  max-width: 800px;
  max-height: 90vh;
  overflow: hidden;
  box-shadow: 0 25px 60px rgba(0, 0, 0, 0.15);
  border: 2px solid #f1f5f9;
}

.cartHeader {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24px 32px;
  border-bottom: 2px solid #f1f5f9;
  background: linear-gradient(135deg, #f8fafc, #ffffff);
}

.cartTitle {
  font-size: 1.5rem;
  font-weight: 700;
  color: #1e293b;
  margin: 0;
  display: flex;
  align-items: center;
  gap: 12px;
}

.cartItemCount {
  font-size: 0.9rem;
  color: #22c55e;
  font-weight: 600;
}

.closeCartButton {
  background: rgba(34, 197, 94, 0.1);
  color: #22c55e;
  border: 2px solid #22c55e;
  border-radius: 8px;
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.3s ease;
}

.closeCartButton:hover {
  background: #22c55e;
  color: white;
  transform: scale(1.1);
}

.cartBody {
  padding: 24px 32px;
  max-height: 60vh;
  overflow-y: auto;
}

/* Empty Cart */
.emptyCart {
  text-align: center;
  padding: 60px 20px;
}

.emptyCartIcon {
  font-size: 4rem;
  margin-bottom: 24px;
  opacity: 0.3;
}

.emptyCart h3 {
  font-size: 1.5rem;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 12px;
}

.emptyCart p {
  color: #64748b;
  margin-bottom: 32px;
}

.continueShopping {
  padding: 12px 24px;
  background: linear-gradient(135deg, #22c55e, #16a34a);
  color: white;
  border: none;
  border-radius: 8px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
}

.continueShopping:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 25px rgba(34, 197, 94, 0.3);
}

/* Cart Items */
.cartItems {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.cartItem {
  display: grid;
  grid-template-columns: 80px 1fr auto auto;
  gap: 16px;
  align-items: center;
  padding: 20px;
  background: #f8fafc;
  border-radius: 16px;
  border: 2px solid #e2e8f0;
  transition: all 0.3s ease;
}

.cartItem:hover {
  border-color: #22c55e;
  box-shadow: 0 4px 16px rgba(34, 197, 94, 0.1);
}

.cartItemImage {
  width: 80px;
  height: 80px;
  border-radius: 12px;
  overflow: hidden;
  border: 2px solid #e2e8f0;
}

.cartItemImage img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.cartItemInfo {
  flex: 1;
}

.cartItemName {
  font-size: 1.1rem;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 4px;
}

.cartItemCategory {
  font-size: 0.9rem;
  color: #64748b;
  margin-bottom: 8px;
}

.cartItemPrice {
  font-size: 1rem;
  font-weight: 600;
  color: #22c55e;
}

.cartItemControls {
  display: flex;
  flex-direction: column;
  gap: 12px;
  align-items: center;
}

.quantityControls {
  display: flex;
  align-items: center;
  gap: 8px;
  background: white;
  border: 2px solid #e2e8f0;
  border-radius: 8px;
  padding: 4px;
}

.quantityBtn {
  width: 32px;
  height: 32px;
  background: transparent;
  border: none;
  border-radius: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  font-weight: 700;
  color: #22c55e;
  transition: all 0.2s ease;
}

.quantityBtn:hover {
  background: rgba(34, 197, 94, 0.1);
}

.quantity {
  font-weight: 600;
  color: #1e293b;
  min-width: 30px;
  text-align: center;
}

.removeBtn {
  background: rgba(239, 68, 68, 0.1);
  color: #ef4444;
  border: 2px solid #ef4444;
  border-radius: 6px;
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.3s ease;
}

.removeBtn:hover {
  background: #ef4444;
  color: white;
  transform: scale(1.1);
}

.cartItemTotal {
  font-size: 1.1rem;
  font-weight: 700;
  color: #1e293b;
  text-align: right;
}

/* Cart Footer */
.cartFooter {
  border-top: 2px solid #e2e8f0;
  padding: 24px 32px;
  background: linear-gradient(135deg, #f8fafc, #ffffff);
}

.cartSummary {
  margin-bottom: 24px;
}

.cartTotal {
  background: white;
  border: 2px solid #e2e8f0;
  border-radius: 12px;
  padding: 20px;
}

.totalRow {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12px;
  font-size: 0.95rem;
  color: #64748b;
}

.totalRowFinal {
  display: flex;
  justify-content: space-between;
  font-size: 1.25rem;
  font-weight: 700;
  color: #1e293b;
  padding-top: 12px;
  border-top: 2px solid #e2e8f0;
}

.cartActions {
  display: flex;
  gap: 16px;
}

.clearCartBtn {
  flex: 1;
  padding: 14px 20px;
  background: transparent;
  color: #64748b;
  border: 2px solid #e2e8f0;
  border-radius: 8px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
}

.clearCartBtn:hover {
  background: #f1f5f9;
  border-color: #cbd5e1;
  color: #475569;
}

.checkoutBtn {
  flex: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  padding: 14px 20px;
  background: linear-gradient(135deg, #22c55e, #16a34a);
  color: white;
  border: none;
  border-radius: 8px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
  font-size: 1.1rem;
  position: relative;
  overflow: hidden;
}

.checkoutBtn:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 25px rgba(34, 197, 94, 0.3);
}

.checkoutBtn:active {
  transform: translateY(0);
  box-shadow: 0 4px 15px rgba(34, 197, 94, 0.25);
}

.checkoutBtn.loading {
  pointer-events: none;
}

.checkoutBtn.loading::after {
  content: "";
  position: absolute;
  top: 0;
  left: -100%;
  width: 300%;
  height: 100%;
  background: linear-gradient(
    90deg,
    rgba(255, 255, 255, 0) 0%,
    rgba(255, 255, 255, 0.2) 50%,
    rgba(255, 255, 255, 0) 100%
  );
  animation: loadingEffect 1.5s infinite;
}

/* Floating Cart */
.floatingCartContainer {
  position: fixed;
  top: 80px;
  right: 24px;
  z-index: 999;
  display: flex;
  flex-direction: column;
  gap: 12px;
  transition: all 0.3s ease;
}

.floatingCart {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 60px;
  height: 60px;
  background: linear-gradient(135deg, #22c55e, #16a34a);
  color: white;
  border-radius: 50%;
  box-shadow: 0 8px 20px rgba(34, 197, 94, 0.3);
  cursor: pointer;
  border: none;
  position: relative;
  transition: all 0.3s ease;
  animation: bounceIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.floatingCart:hover {
  transform: translateY(-3px) scale(1.05);
  box-shadow: 0 12px 25px rgba(34, 197, 94, 0.4);
}

.floatingCart:active {
  transform: translateY(0) scale(0.95);
  box-shadow: 0 6px 15px rgba(34, 197, 94, 0.3);
}

.floatingCartCount {
  position: absolute;
  top: -6px;
  right: -6px;
  background: #ef4444;
  color: white;
  font-size: 12px;
  font-weight: 700;
  min-width: 20px;
  height: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20px;
  padding: 0 6px;
  animation: pulse 2s infinite;
}

.floatingCartTotal {
  position: absolute;
  bottom: -8px;
  left: 50%;
  transform: translateX(-50%);
  background: #1e293b;
  color: white;
  font-size: 11px;
  font-weight: 600;
  padding: 3px 8px;
  border-radius: 20px;
  white-space: nowrap;
  opacity: 0;
  transition: all 0.3s ease;
}

.floatingCart:hover .floatingCartTotal {
  opacity: 1;
  bottom: -15px;
}

.floatingMiniCart {
  position: absolute;
  top: 75px;
  right: 0;
  width: 320px;
  background: white;
  border-radius: 16px;
  box-shadow: 0 15px 50px rgba(0, 0, 0, 0.15);
  padding: 16px;
  transform: translateY(20px);
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  overflow: hidden;
  border: 2px solid #f1f5f9;
}

.floatingMiniCart.visible {
  transform: translateY(0);
  opacity: 1;
  visibility: visible;
}

.miniCartHeader {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
  padding-bottom: 12px;
  border-bottom: 1px solid #e2e8f0;
}

.miniCartTitle {
  font-size: 14px;
  font-weight: 700;
  color: #1e293b;
  margin: 0;
  display: flex;
  align-items: center;
  gap: 8px;
}

.miniCartItemCount {
  font-size: 12px;
  color: #22c55e;
  font-weight: 600;
}

.miniCartBody {
  max-height: 250px;
  overflow-y: auto;
  margin-bottom: 12px;
  padding-right: 6px;
}

.miniCartBody::-webkit-scrollbar {
  width: 5px;
}

.miniCartBody::-webkit-scrollbar-track {
  background: #f1f5f9;
  border-radius: 10px;
}

.miniCartBody::-webkit-scrollbar-thumb {
  background: #cbd5e1;
  border-radius: 10px;
}

.miniCartItem {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 10px 0;
  border-bottom: 1px solid #f1f5f9;
}

.miniCartItemImage {
  width: 50px;
  height: 50px;
  border-radius: 8px;
  overflow: hidden;
  background: #f1f5f9;
  flex-shrink: 0;
}

.miniCartItemImage img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.miniCartItemInfo {
  flex: 1;
  min-width: 0;
}

.miniCartItemName {
  font-size: 13px;
  font-weight: 600;
  color: #1e293b;
  margin: 0 0 4px 0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.miniCartItemPrice {
  font-size: 12px;
  font-weight: 700;
  color: #16a34a;
}

.miniCartQuantity {
  font-size: 11px;
  color: #64748b;
}

.miniCartFooter {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.miniCartTotal {
  display: flex;
  justify-content: space-between;
  font-size: 14px;
  font-weight: 600;
  padding-top: 10px;
  border-top: 1px solid #f1f5f9;
  color: #1e293b;
}

.miniCartActions {
  display: flex;
  gap: 10px;
}

.viewCartBtn,
.checkoutMiniBtn {
  flex: 1;
  padding: 10px 0;
  font-size: 12px;
  font-weight: 600;
  text-align: center;
  border-radius: 8px;
  transition: all 0.3s ease;
  cursor: pointer;
}

.viewCartBtn {
  background: #f8fafc;
  color: #64748b;
  border: 1px solid #e2e8f0;
}

.viewCartBtn:hover {
  background: #f1f5f9;
  color: #475569;
}

.checkoutMiniBtn {
  background: linear-gradient(135deg, #22c55e, #16a34a);
  color: white;
  border: none;
}

.checkoutMiniBtn:hover {
  transform: translateY(-2px);
  box-shadow: 0 4px 12px rgba(34, 197, 94, 0.2);
}

.emptyMiniCart {
  text-align: center;
  padding: 20px 10px;
}

.emptyMiniCartIcon {
  font-size: 24px;
  margin-bottom: 8px;
  opacity: 0.3;
}

.emptyMiniCart h5 {
  font-size: 14px;
  font-weight: 600;
  color: #1e293b;
  margin: 0 0 8px 0;
}

.emptyMiniCart p {
  font-size: 12px;
  color: #64748b;
  margin: 0 0 16px 0;
}

.startShoppingBtn {
  background: linear-gradient(135deg, #22c55e, #16a34a);
  color: white;
  border: none;
  border-radius: 8px;
  padding: 8px 16px;
  font-size: 12px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
}

.startShoppingBtn:hover {
  transform: translateY(-2px);
  box-shadow: 0 4px 12px rgba(34, 197, 94, 0.2);
}

@keyframes bounceIn {
  0% {
    opacity: 0;
    transform: scale(0.3);
  }
  50% {
    opacity: 1;
    transform: scale(1.05);
  }
  70% {
    transform: scale(0.9);
  }
  100% {
    transform: scale(1);
  }
}

/* Animations */
@keyframes float {
  0%,
  100% {
    transform: translateY(0px) rotate(0deg);
  }
  50% {
    transform: translateY(-15px) rotate(3deg);
  }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeIn {
  to {
    opacity: 1;
  }
}

@keyframes scaleIn {
  to {
    transform: scale(1);
  }
}

@keyframes loadingEffect {
  0% {
    left: -100%;
  }
  100% {
    left: 100%;
  }
}

/* ===== RESPONSIVE DESIGN ===== */

/* Large Desktop (1200px+) - 3 columnas */
@media (min-width: 1200px) {
  .productsGrid {
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
}

/* Desktop (1024px - 1199px) - 3 columnas */
@media (min-width: 1024px) and (max-width: 1199px) {
  .container {
    padding: 0 20px;
  }

  .title {
    font-size: 3.5rem;
  }

  .productsGrid {
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .productCard {
    padding: 20px;
  }

  .productImageContainer {
    height: 220px;
  }

  .productInfo {
    padding: 20px;
  }

  .addToCartBtn {
    padding: 12px 16px;
    font-size: 0.9rem;
  }
}

/* Tablets (768px - 1023px) - 2 columnas verticales */
@media (min-width: 768px) and (max-width: 1023px) {
  .container {
    padding: 0 20px;
  }

  .title {
    font-size: 3rem;
  }

  .subtitle {
    font-size: 1.15rem;
  }

  .productsGrid {
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .productCard {
    padding: 18px;
  }

  .productImageContainer {
    height: 200px;
  }

  .productInfo {
    padding: 18px;
  }

  .productName {
    font-size: 1.2rem;
  }

  .productDescription {
    font-size: 0.9rem;
  }

  .productPrice {
    font-size: 1.6rem;
  }

  .addToCartBtn {
    padding: 12px 16px;
    font-size: 0.9rem;
  }

  .categoriesGrid {
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 16px;
  }
}

/* Móviles (hasta 767px) - 1 columna vertical */
@media (max-width: 767px) {
  .container {
    padding: 0 16px;
  }

  .shop {
    padding: 60px 0;
  }

  .shop.noNavigation {
    padding: 40px 0;
  }

  .title {
    font-size: 2.5rem;
    text-align: center;
  }

  .subtitle {
    font-size: 1rem;
    text-align: center;
  }

  /* Categorías: 2 columnas en móvil */
  .categoriesGrid {
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }

  .categoryCard {
    padding: 16px 12px;
    border-radius: 12px;
  }

  .categoryIcon {
    width: 32px;
    height: 32px;
    margin-bottom: 8px;
  }

  .categoryName {
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 4px;
  }

  .categoryDescription {
    font-size: 0.75rem;
    margin-bottom: 8px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .categoryCount {
    font-size: 0.75rem;
    padding: 4px 8px;
  }

  /* Productos: 1 columna vertical en móvil */
  .productsGrid {
    grid-template-columns: 1fr;
    gap: 16px;
    margin-bottom: 40px;
  }

  .productCard {
    /* Mantener diseño vertical como desktop */
    display: flex;
    flex-direction: column;
    padding: 16px;
    border-radius: 12px;
  }

  .productImageContainer {
    /* Imagen arriba, información abajo */
    width: 100%;
    height: 180px;
    border-radius: 12px;
    margin-bottom: 12px;
  }

  .productInfo {
    padding: 12px;
    flex-grow: 1;
  }

  .productCategory {
    font-size: 0.75rem;
    padding: 4px 8px;
    margin-bottom: 8px;
  }

  .productName {
    font-size: 1rem;
    line-height: 1.3;
    margin-bottom: 8px;
  }

  .productDescription {
    font-size: 0.85rem;
    margin-bottom: 12px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .productRating {
    margin-bottom: 10px;
    gap: 6px;
  }

  .stars {
    font-size: 0.8rem;
    gap: 2px;
  }

  .starFilled,
  .star {
    font-size: 0.8rem;
  }

  .ratingValue {
    font-size: 0.75rem;
  }

  .productTags {
    margin-bottom: 10px;
    gap: 4px;
  }

  .tag {
    padding: 3px 6px;
    font-size: 0.7rem;
    border-radius: 6px;
  }

  .stockInfo {
    font-size: 0.8rem;
    margin-bottom: 12px;
  }

  .stockDot {
    width: 6px;
    height: 6px;
  }

  .productPrice {
    font-size: 1.4rem;
    margin-bottom: 12px;
    text-align: center;
  }

  .originalPrice {
    font-size: 1rem;
  }

  .currentPrice {
    font-size: 1.4rem;
  }

  .addToCartBtn {
    padding: 12px 16px;
    font-size: 0.9rem;
    border-radius: 8px;
    width: 100%;
    min-height: 44px;
  }

  /* Headers y títulos */
  .productsHeader {
    flex-direction: column;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
    text-align: center;
  }

  .productsTitle {
    font-size: 1.8rem;
    font-weight: 700;
  }

  .productsCount {
    font-size: 0.9rem;
    padding: 6px 12px;
  }

  /* Modal responsive */
  .modalBody {
    grid-template-columns: 1fr;
    gap: 24px;
    padding: 24px 16px;
  }

  .modalActions {
    flex-direction: column;
    gap: 12px;
  }

  /* Floating cart */
  .floatingCartContainer {
    top: 70px;
    right: 16px;
  }

  .floatingCart {
    width: 50px;
    height: 50px;
  }

  .floatingMiniCart {
    width: 280px;
    top: 65px;
  }
}

/* Media Query para móviles grandes (481px - 767px) */
@media (min-width: 481px) and (max-width: 767px) {
  .container {
    padding: 0 20px;
  }

  .title {
    font-size: 2.5rem;
    text-align: center;
  }

  .subtitle {
    font-size: 1.1rem;
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .categoriesSection {
    margin-bottom: 50px;
  }

  .productsSection {
    margin-bottom: 50px;
  }

  .productsHeader {
    margin-bottom: 35px;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
  }

  .productsTitle {
    font-size: 2rem;
    font-weight: 700;
  }

  .productsCount {
    font-size: 1rem;
    padding: 8px 14px;
  }

  /* Categorías: 3 columnas para móviles grandes */
  .categoriesGrid {
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }

  .categoryCard {
    padding: 20px 12px;
    border-radius: 14px;
  }

  .categoryIcon {
    width: 40px;
    height: 40px;
    margin-bottom: 10px;
  }

  .categoryName {
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 6px;
  }

  .categoryDescription {
    font-size: 0.8rem;
    margin-bottom: 10px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .categoryCount {
    font-size: 0.8rem;
    padding: 6px 10px;
  }

  /* Productos: 1 columna para móviles grandes con diseño horizontal */
  .productsGrid {
    grid-template-columns: 1fr;
    gap: 14px;
    margin-bottom: 45px;
  }

  .productCard {
    display: grid;
    grid-template-columns: 100px 1fr;
    grid-template-rows: auto auto;
    align-items: start;
    gap: 12px;
    padding: 16px;
    min-height: 100px;
    border-radius: 12px;
  }

  .productImageContainer {
    width: 100px;
    height: 80px;
    border-radius: 10px;
    grid-row: 1 / 3;
  }

  .productInfo {
    padding: 0;
    gap: 4px;
    grid-column: 2;
    grid-row: 1;
  }

  .productActions {
    grid-column: 2;
    grid-row: 2;
    width: 100%;
    min-width: auto;
    align-items: flex-end;
    margin-top: 8px;
  }

  .productName {
    font-size: 0.9rem;
    margin-bottom: 4px;
  }

  .productDescription {
    font-size: 0.8rem;
    margin-bottom: 6px;
  }

  .productPrice {
    font-size: 1.1rem;
    margin-bottom: 8px;
    text-align: left;
  }

  .addToCartBtn {
    padding: 8px 12px;
    font-size: 0.8rem;
    min-height: 32px;
    width: 100%;
  }

  .productCard {
    border-radius: 10px;
  }

  .productImageContainer {
    height: 90px;
  }

  .productBadges {
    top: 6px;
    left: 6px;
    gap: 3px;
  }

  .discountBadge,
  .featuredBadge {
    padding: 2px 6px;
    font-size: 0.65rem;
    border-radius: 8px;
  }

  .productInfo {
    padding: 8px 6px;
  }

  .productCategory {
    font-size: 0.65rem;
    margin-bottom: 4px;
  }

  .productName {
    font-size: 0.8rem;
    margin-bottom: 4px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .productDescription {
    font-size: 0.7rem;
    margin-bottom: 6px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .productPrice {
    font-size: 0.85rem;
    margin-bottom: 6px;
  }

  .originalPrice {
    font-size: 0.7rem;
  }

  .currentPrice {
    font-size: 0.85rem;
  }

  .productRating {
    margin-bottom: 4px;
    gap: 6px;
  }

  .stars {
    font-size: 0.65rem;
    gap: 2px;
  }

  .starFilled,
  .star {
    font-size: 0.65rem;
  }

  .ratingValue {
    font-size: 0.6rem;
  }

  .productTags {
    margin-bottom: 6px;
    gap: 3px;
  }

  .tag {
    padding: 2px 5px;
    font-size: 0.65rem;
    border-radius: 6px;
  }

  .stockInfo {
    font-size: 0.65rem;
    margin-bottom: 6px;
  }

  .stockDot {
    width: 5px;
    height: 5px;
  }

  .inStock,
  .outOfStock {
    font-size: 0.65rem;
    font-weight: 600;
  }

  .addToCartBtn {
    padding: 5px 7px;
    font-size: 0.65rem;
    border-radius: 5px;
    width: 100%;
    height: 26px;
    min-height: 26px;
  }
}

@media (max-width: 480px) {
  .shop {
    padding: 60px 0;
  }

  .shop.noNavigation {
    padding: 40px 0;
  }

  .container {
    padding: 0 12px;
  }

  .title {
    font-size: 2.2rem;
    text-align: center;
  }

  .subtitle {
    font-size: 1rem;
    text-align: center;
    margin-bottom: 2rem;
  }

  .categoriesSection {
    margin-bottom: 40px;
  }

  .productsSection {
    margin-bottom: 40px;
  }

  .productsHeader {
    margin-bottom: 30px;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 12px;
  }

  .productsTitle {
    font-size: 1.8rem;
    font-weight: 700;
  }

  .productsCount {
    font-size: 0.9rem;
    padding: 6px 12px;
  }

  /* Categorías: 2 columnas en móvil con mejor espaciado */
  .categoriesGrid {
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    margin-bottom: 30px;
  }

  .categoryCard {
    padding: 20px 16px;
    border-radius: 16px;
    border: 2px solid rgba(4, 120, 87, 0.1);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    min-height: 140px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .categoryCard:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 35px rgba(4, 120, 87, 0.15);
    border-color: rgba(4, 120, 87, 0.25);
  }

  .categoryCard.active {
    border-color: rgba(4, 120, 87, 0.4);
    background: rgba(4, 120, 87, 0.05);
    box-shadow: 0 8px 30px rgba(4, 120, 87, 0.2);
  }

  .categoryIcon {
    width: 40px;
    height: 40px;
    margin-bottom: 12px;
    font-size: 1.8rem;
  }

  .categoryName {
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 6px;
    color: #1f2937;
  }

  .categoryDescription {
    font-size: 0.8rem;
    line-height: 1.3;
    margin-bottom: 10px;
    color: #6b7280;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .categoryCount {
    font-size: 0.75rem;
    padding: 6px 12px;
    background: rgba(4, 120, 87, 0.1);
    color: #047857;
    border-radius: 12px;
    font-weight: 600;
    margin-top: auto;
  }

  /* Search y Filtros optimizados para móvil */
  .searchSection {
    margin-bottom: 30px;
  }

  .searchContainer {
    padding: 20px 16px;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(15px);
  }

  .searchBar {
    margin-bottom: 20px;
  }

  .searchInput {
    padding: 16px 20px 16px 50px;
    font-size: 16px;
    border-radius: 14px;
    border: 2px solid rgba(0, 0, 0, 0.08);
  }

  .searchInput:focus {
    border-color: #047857;
    box-shadow: 0 0 0 3px rgba(4, 120, 87, 0.1);
  }

  .searchIcon {
    left: 18px;
    font-size: 18px;
  }

  .filterRow {
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: stretch;
  }

  .sortSelect {
    padding: 14px 16px;
    font-size: 15px;
    border-radius: 12px;
    border: 2px solid rgba(0, 0, 0, 0.08);
    background: white;
    order: 1;
  }

  .filterToggle {
    padding: 14px 20px;
    font-size: 15px;
    border-radius: 12px;
    background: #047857;
    color: white;
    border: none;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    order: 2;
  }

  .filterToggle:hover {
    background: #065f46;
  }

  .advancedFilters {
    margin-top: 16px;
    padding: 20px;
    border-radius: 16px;
    background: rgba(4, 120, 87, 0.02);
    border: 1px solid rgba(4, 120, 87, 0.1);
  }

  .filterGroup {
    margin-bottom: 0;
  }

  .filterLabel {
    font-size: 15px;
    font-weight: 600;
    margin-bottom: 12px;
    color: #1f2937;
  }

  .priceRange {
    gap: 12px;
  }

  .rangeSlider {
    height: 6px;
    border-radius: 3px;
  }

  .rangeValues {
    font-size: 14px;
    font-weight: 600;
    gap: 12px;
  }

  /* Productos: 1 columna en móvil con diseño vertical compacto */
  .productsGrid {
    grid-template-columns: 1fr;
    gap: 12px;
    margin-bottom: 50px;
  }

  .productCard {
    border-radius: 14px;
    border: 2px solid rgba(4, 120, 87, 0.12);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
    overflow: hidden;
    padding: 0;
    display: flex;
    flex-direction: column;
    min-height: auto;
  }

  .productCard:hover {
    transform: translateY(-8px);
    box-shadow: 0 25px 55px rgba(4, 120, 87, 0.22);
    border-color: rgba(4, 120, 87, 0.4);
  }

  .productCard.featured {
    border-color: rgba(4, 120, 87, 0.4);
    box-shadow: 0 12px 40px rgba(4, 120, 87, 0.16);
  }

  .productImageContainer {
    width: 100%;
    height: 140px;
    position: relative;
    border-radius: 0;
    overflow: hidden;
  }

  .productImage {
    height: 100%;
    object-fit: cover;
  }

  .productBadges {
    top: 4px;
    left: 4px;
    gap: 2px;
  }

  .discountBadge,
  .featuredBadge {
    padding: 1px 4px;
    font-size: 0.5rem;
    border-radius: 6px;
  }

  .productInfo {
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .productCategory {
    font-size: 0.7rem;
    margin-bottom: 6px;
    text-transform: uppercase;
    color: #047857;
    font-weight: 600;
    background: rgba(4, 120, 87, 0.1);
    padding: 4px 8px;
    border-radius: 8px;
    width: fit-content;
    align-self: center;
  }

  .productName {
    font-size: 0.7rem;
    line-height: 1.1;
    margin-bottom: 4px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-weight: 700;
    color: #1f2937;
    text-align: center;
    min-height: 2rem;
  }

  .productDescription {
    font-size: 0.6rem;
    line-height: 1.1;
    margin-bottom: 6px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    color: #6b7280;
    text-align: center;
    flex-grow: 1;
  }

  .productPrice {
    font-size: 0.75rem;
    font-weight: 800;
    margin-bottom: 6px;
    text-align: center;
  }

  .originalPrice {
    font-size: 0.7rem;
    text-decoration: line-through;
    color: #9ca3af;
    margin-right: 6px;
  }

  .currentPrice {
    font-size: 0.85rem;
    color: #059669;
    font-weight: 800;
  }

  .productRating {
    margin-bottom: 8px;
    gap: 4px;
    justify-content: center;
    align-items: center;
  }

  .stars {
    font-size: 0.65rem;
    gap: 1px;
  }

  .starFilled,
  .star {
    font-size: 0.65rem;
  }

  .ratingValue {
    font-size: 0.6rem;
    color: #6b7280;
    font-weight: 600;
  }

  .productTags {
    margin-bottom: 8px;
    gap: 3px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .tag {
    padding: 2px 5px;
    font-size: 0.55rem;
    border-radius: 4px;
    background: rgba(4, 120, 87, 0.1);
    color: #047857;
    font-weight: 600;
  }

  .stockInfo {
    font-size: 0.65rem;
    margin-bottom: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
  }

  .stockDot {
    width: 5px;
    height: 5px;
  }

  .inStock {
    font-size: 0.65rem;
    font-weight: 700;
    color: #16a34a;
  }

  .outOfStock {
    font-size: 0.65rem;
    font-weight: 700;
    color: #dc2626;
  }

  /* Botón siempre en la parte inferior */
  .addToCartBtn {
    padding: 8px 6px;
    font-size: 0.65rem;
    border-radius: 6px;
    width: 100%;
    height: 30px;
    min-height: 30px;
    background: linear-gradient(135deg, #059669, #047857);
    color: white;
    border: none;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 3px;
    transition: all 0.3s ease;
    margin-top: 6px;
  }

  .addToCartBtn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(5, 150, 105, 0.3);
  }

  .addToCartBtn:active {
    transform: translateY(0);
  }

  .modalContent {
    width: 95%;
    margin: 16px;
  }

  .modalBody {
    padding: 20px 16px;
  }

  .closeButton {
    top: 12px;
    right: 12px;
    width: 32px;
    height: 32px;
  }

  .gradientOrb1,
  .gradientOrb2,
  .gradientOrb3 {
    width: 150px;
    height: 150px;
  }
}

/* Media Query para pantallas extra pequeñas */
@media (max-width: 360px) {
  .container {
    padding: 0 8px;
  }

  .title {
    font-size: 1.8rem;
    text-align: center;
  }

  .subtitle {
    font-size: 0.9rem;
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .categoriesSection {
    margin-bottom: 30px;
  }

  .productsSection {
    margin-bottom: 30px;
  }

  .productsHeader {
    margin-bottom: 25px;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 10px;
  }

  .productsTitle {
    font-size: 1.6rem;
    font-weight: 700;
  }

  .productsCount {
    font-size: 0.8rem;
    padding: 5px 10px;
  }

  /* Categorías: 3 columnas muy compactas */
  .categoriesGrid {
    grid-template-columns: repeat(3, 1fr);
    gap: 6px;
  }

  .categoryCard {
    padding: 12px 6px;
    border-radius: 10px;
  }

  .categoryIcon {
    width: 28px;
    height: 28px;
    margin-bottom: 6px;
  }

  .categoryName {
    font-size: 0.7rem;
    font-weight: 600;
    line-height: 1.1;
    margin-bottom: 3px;
  }

  .categoryDescription {
    font-size: 0.6rem;
    line-height: 1.1;
    margin-bottom: 6px;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .categoryCount {
    font-size: 0.6rem;
    padding: 3px 6px;
  }

  /* Productos: 3 columnas extremadamente compactas */
  .productsGrid {
    grid-template-columns: repeat(3, 1fr);
    gap: 4px;
    margin-bottom: 25px;
  }

  .productCard {
    border-radius: 6px;
    overflow: hidden;
    box-sizing: border-box;
  }

  .productImageContainer {
    height: 65px;
  }

  .productBadges {
    top: 3px;
    left: 3px;
    gap: 1px;
  }

  .discountBadge,
  .featuredBadge {
    padding: 1px 3px;
    font-size: 0.45rem;
    border-radius: 4px;
  }

  .productInfo {
    padding: 3px 4px;
    box-sizing: border-box;
    overflow: hidden;
  }

  .productCategory {
    font-size: 0.45rem;
    margin-bottom: 1px;
  }

  .productName {
    font-size: 0.6rem;
    line-height: 1.1;
    margin-bottom: 2px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .productDescription {
    font-size: 0.5rem;
    line-height: 1.1;
    margin-bottom: 3px;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .productPrice {
    font-size: 0.65rem;
    font-weight: 700;
    margin-bottom: 2px;
  }

  .originalPrice {
    font-size: 0.5rem;
  }

  .currentPrice {
    font-size: 0.65rem;
  }

  .productRating {
    margin-bottom: 1px;
    gap: 3px;
  }

  .stars {
    font-size: 0.45rem;
    gap: 1px;
  }

  .starFilled,
  .star {
    font-size: 0.45rem;
  }

  .ratingValue {
    font-size: 0.4rem;
  }

  .productTags {
    margin-bottom: 3px;
    gap: 1px;
  }

  .tag {
    padding: 1px 2px;
    font-size: 0.45rem;
    border-radius: 3px;
  }

  .stockInfo {
    font-size: 0.5rem;
    margin-bottom: 3px;
  }

  .stockDot {
    width: 3px;
    height: 3px;
  }

  .inStock,
  .outOfStock {
    font-size: 0.5rem;
    font-weight: 600;
  }

  .addToCartBtn {
    padding: 2px 4px;
    font-size: 0.45rem;
    border-radius: 3px;
    width: calc(100% - 4px);
    height: 18px;
    min-height: 18px;
    margin: 0 2px;
    box-sizing: border-box;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
}

/* Responsive Cart Styles */
@media (max-width: 768px) {
  .cartModalContent {
    margin: 10px;
    max-height: calc(100vh - 20px);
  }

  .cartHeader {
    padding: 20px;
  }

  .cartTitle {
    font-size: 1.25rem;
  }

  .cartBody {
    padding: 20px;
  }

  .cartItem {
    grid-template-columns: 60px 1fr;
    grid-template-rows: auto auto;
    gap: 12px;
  }

  .cartItemImage {
    width: 60px;
    height: 60px;
  }

  .cartItemControls {
    grid-column: 1 / -1;
    flex-direction: row;
    justify-content: space-between;
  }

  .cartItemTotal {
    grid-column: 1 / -1;
    text-align: center;
    font-size: 1.2rem;
    padding: 12px;
    background: rgba(34, 197, 94, 0.1);
    border-radius: 8px;
    color: #22c55e;
  }

  .cartFooter {
    padding: 20px;
  }

  .cartActions {
    flex-direction: column;
  }

  .headerTop {
    text-align: center;
    margin-top: 50px;
  }
}

/* Enhanced Modal Responsive Styles */
@media (max-width: 768px) {
  .modalBody {
    grid-template-columns: 1fr;
    gap: 24px;
    padding: 24px;
  }

  .modalTitle {
    font-size: 1.5rem;
  }

  .modalMainImage {
    height: 300px;
  }

  .modalCurrentPrice {
    font-size: 1.5rem;
  }

  .modalActions {
    flex-direction: column;
  }

  .modalAddToCart,
  .modalContactExpert {
    flex: 1;
  }

  .modalQuantitySection {
    justify-content: center;
  }

  .specsTitle {
    font-size: 1rem;
  }

  .modalSpecifications {
    padding: 16px;
  }
}

@media (max-width: 480px) {
  .modalContent {
    width: 98%;
    border-radius: 16px;
  }

  .modalBody {
    padding: 16px;
  }

  .closeButton {
    top: 12px;
    right: 12px;
    width: 32px;
    height: 32px;
  }

  .modalTitle {
    font-size: 1.3rem;
  }

  .modalMainImage {
    height: 250px;
  }

  .galleryThumb {
    width: 50px;
    height: 50px;
  }

  .modalQuantityBtn {
    width: 28px;
    height: 28px;
  }

  .modalActions {
    gap: 8px;
  }

  .modalAddToCart,
  .modalContactExpert {
    padding: 12px 16px;
    font-size: 0.9rem;
  }
}
